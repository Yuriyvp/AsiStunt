{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["name", "version", "voice", "mood", "language", "llm", "personality"],
  "properties": {
    "name": {"type": "string"},
    "version": {"type": "integer", "minimum": 2},
    "voice": {
      "type": "object",
      "required": ["languages"],
      "properties": {
        "languages": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id"],
            "properties": {
              "id": {"type": "string"},
              "reference_audio": {"type": ["string", "null"]}
            }
          },
          "minItems": 1,
          "maxItems": 3
        }
      }
    },
    "mood": {
      "type": "object",
      "required": ["default", "range"],
      "properties": {
        "default": {"type": "string"},
        "range": {"type": "array", "items": {"type": "string"}, "minItems": 1}
      }
    },
    "memory": {
      "type": "object",
      "properties": {
        "summary_style": {"type": "string"},
        "summary_budget_trigger": {"type": "number", "minimum": 0, "maximum": 1}
      }
    },
    "language": {
      "type": "object",
      "required": ["default"],
      "properties": {
        "default": {"type": "string"}
      }
    },
    "llm": {
      "type": "object",
      "required": ["model"],
      "properties": {
        "model": {"type": "string"},
        "ctx_size": {"type": "integer", "minimum": 512},
        "port": {"type": "integer", "minimum": 1, "maximum": 65535},
        "gpu_layers": {"type": "integer", "minimum": 0},
        "threads": {"type": "integer", "minimum": 1},
        "batch_size": {"type": "integer", "minimum": 1},
        "flash_attn": {"type": "boolean"},
        "sampling": {
          "type": "object",
          "properties": {
            "temperature": {"type": "number", "minimum": 0},
            "top_p": {"type": "number", "minimum": 0, "maximum": 1},
            "top_k": {"type": "integer", "minimum": 0},
            "min_p": {"type": "number", "minimum": 0, "maximum": 1},
            "repeat_penalty": {"type": "number", "minimum": 0},
            "repeat_last_n": {"type": "integer", "minimum": 0}
          }
        }
      }
    },
    "personality": {"type": "string"},
    "backstory": {"type": "string"},
    "session_restore_hours": {"type": "number", "minimum": 0}
  }
}
